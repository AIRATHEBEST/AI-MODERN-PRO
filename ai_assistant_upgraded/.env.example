# ═══════════════════════════════════════════════════════════════════
#  AI Assistant — Environment Configuration
#  Copy this file to .env and fill in the values you need.
#  You do NOT need all providers — only the ones you want to use.
# ═══════════════════════════════════════════════════════════════════

# ── Database (required) ──────────────────────────────────────────
DATABASE_URL=mysql://user:password@localhost:3306/ai_assistant

# ── App ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
JWT_SECRET=change-me-to-a-random-secret-string

# ── Built-in fallback (uses OpenAI-compatible endpoint) ──────────
# Leave blank to disable built-in mode; add your OpenAI key here for
# the fallback provider used when no provider is explicitly selected.
LLM_API_KEY=
LLM_API_URL=https://api.openai.com

# ── Provider API Keys (add the ones you want) ────────────────────
# These are optional — users can also add keys via the Settings panel.

# OpenAI  https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic Claude  https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini  https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=AIza...

# Deepseek  https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-...

# Grok (xAI)  https://console.x.ai
GROK_API_KEY=xai-...

# Hugging Face  https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_...

# Puter (optional — puter.js handles browser auth for free)
# Set this only if you want server-side Puter access
PUTER_API_KEY=

# ── Ollama (local models) ─────────────────────────────────────────
# URL of your running Ollama instance
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# ── AWS S3 (optional file storage) ───────────────────────────────
# Leave blank to use local disk storage
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
