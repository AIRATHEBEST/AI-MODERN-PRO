# ═══════════════════════════════════════════════════════
#  AI Assistant — Environment Configuration
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────────────────
# MySQL connection string
DATABASE_URL=mysql://user:password@localhost:3306/ai_assistant

# JWT secret for session cookies (any random string ≥32 chars)
JWT_SECRET=change-this-to-a-long-random-secret-string

# ── OPTIONAL: Set a default LLM key ─────────────────────
# These keys are used as server-side fallbacks if no per-user key is set.
# Users can also add their own keys in Settings.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
DEEPSEEK_API_KEY=sk-...
GROK_API_KEY=xai-...
HUGGINGFACE_API_KEY=hf_...
# Puter is FREE — no key needed for built-in Puter auth

# ── OLLAMA ───────────────────────────────────────────────
# Base URL for local Ollama instance (auto-detected)
OLLAMA_BASE_URL=http://localhost:11434

# ── APP ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Owner open ID — this account gets admin role
OWNER_OPEN_ID=

# Auth providers (optional — users can also use guest/magic link)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
